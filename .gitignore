# Ignora a pasta .venv que o VS Code criou (aquela cheia de arquivos)
.venv/
venv/
env/

# Ignora as planilhas com os emails e outros dados dos alunos (privacidade)
data/*.xlsx
data/*.csv

# Ignora os certificados que o Python vai gerar (pra não lotar o GitHub de fotos)
